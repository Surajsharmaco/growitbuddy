# ─────────────────────────────────────────────
# GrowitBuddy — Environment Variables Template
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to git.


# ── REQUIRED ──────────────────────────────────

# PostgreSQL connection string
# Get this from: Supabase, Neon, Railway Postgres, or your VPS
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/growitbuddy

# Admin panel super-admin password
# This is the password used on the "Super Admin" login tab
ADMIN_PASSWORD=your-strong-password-here

# Port the API server will listen on
# Most hosting platforms set this automatically
PORT=8080


# ── FILE UPLOADS ──────────────────────────────

# Where uploaded images are stored on disk.
# On a VPS: point this to a persistent volume path.
# On ephemeral hosting (Railway, Render free): use cloud storage instead.
# Default (if not set): ./uploads folder inside the api-server build directory
#
# VPS example:
# UPLOADS_DIR=/var/www/growitbuddy/uploads
#
# Leave blank to use default:
# UPLOADS_DIR=


# ── AI FEATURES ───────────────────────────────

# The AI SEO analyzer runs entirely on the server without any external API.
# No API key needed. It works automatically out of the box.

# ── NODE ENV ──────────────────────────────────

# Set to "production" on live server
NODE_ENV=production
